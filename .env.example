# claude-cli-cloud-run — env. Copy to `.env` and fill in.
# docker compose reads .env automatically from this directory.
# Optional file — compose works fine without a .env at all.

# Optional: GitHub PAT (classic or fine-grained). When set, the entrypoint
# runs `gh auth login --with-token` on first start (skipped if state/gh/
# already shows authenticated). If unset, run `gh auth login` interactively
# inside the container.
GH_TOKEN=

# REQUIRED for SSH: public key(s) authorized for the `claude` user. Written
# into ~claude/.ssh/authorized_keys at container start. Without this, sshd
# is up but no key can log in. Multiline values OK (use quotes). Example:
#   AUTHORIZED_KEYS="ssh-ed25519 AAAA... you@host"
AUTHORIZED_KEYS=
