# claude-cli-cloud-run — env. Copy to `.env` and fill in. docker compose reads
# .env automatically. All optional except AUTHORIZED_KEYS (needed for SSH login).
# These mirror the Helm chart's values; compose passes them to the same entrypoint.

# REQUIRED for SSH: public key(s) authorized for the `claude` user (merged into
# ~claude/.ssh/authorized_keys at start). Multiline OK (quote it). Example:
#   AUTHORIZED_KEYS="ssh-ed25519 AAAA... you@host"
AUTHORIZED_KEYS=

# GitHub PAT — entrypoint runs `gh auth login --with-token` if set.
GH_TOKEN=

# HuggingFace token (exported for SSH/login shells).
HF_TOKEN=

# Claude credentials.json content (single-line JSON from ~/.claude/.credentials.json).
# Bootstrapped onto the mount once; the CLI then owns + rotates it. Re-seeds only
# when this value changes. Example:
#   CLAUDE_CREDENTIALS_JSON={"claudeAiOauth":{"accessToken":"sk-ant-oat01-...","refreshToken":"sk-ant-ort01-...","expiresAt":...}}
CLAUDE_CREDENTIALS_JSON=

# YouTrack MCP — set BOTH the host and YT_TOKEN to enable it (issues via MCP,
# articles via REST with the same token). Leave host empty to disable.
YT_HOST=
YT_TOKEN=

# Web server (caddy on :8080, published to localhost:8080). "true" to enable.
CLAUDE_WEB_ENABLED=true

# Orchestrator autostart (detached tmux session running claude --remote-control).
# Name the RC session so it starts fresh + is recognizable (no name → reattaches
# to the prior cloud session). Leave CLAUDE_AUTOSTART_CLAUDE_COMMAND unset to use
# the compose default.
CLAUDE_AUTOSTART_TMUX_SESSION_NAME=claude
# CLAUDE_AUTOSTART_CLAUDE_COMMAND=claude --remote-control "My Orchestrator" --dangerously-skip-permissions
